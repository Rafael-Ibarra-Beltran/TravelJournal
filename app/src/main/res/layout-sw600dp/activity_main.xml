<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/notion_surface_soft"
    android:orientation="horizontal"
    android:padding="24dp"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="340dp"
        android:layout_height="match_parent"
        android:background="@drawable/bg_card"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/mainTitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/main_title"
            android:textColor="@color/notion_ink"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/mainSubtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/main_subtitle"
            android:textColor="@color/notion_slate"
            android:textSize="14sp" />

        <Button
            android:id="@+id/addTripButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_button_primary"
            android:text="@string/add_trip"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/emptyStateLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card_lavender"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/empty_trips"
                android:textColor="@color/notion_ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/empty_trips_hint"
                android:textColor="@color/notion_slate"
                android:textSize="14sp" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/tripsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="18dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp"
            tools:listitem="@layout/item_trip" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="24dp"
        android:layout_weight="1">

        <TextView
            android:id="@+id/tabletEmptyDetailText"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_card"
            android:gravity="center"
            android:padding="32dp"
            android:text="@string/tablet_empty_detail"
            android:textColor="@color/notion_slate"
            android:textSize="20sp" />

        <LinearLayout
            android:id="@+id/tabletDetailPanel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/tabletImageView"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:background="@drawable/bg_image_placeholder"
                android:contentDescription="@string/select_image"
                android:scaleType="centerCrop" />

            <TextView
                android:id="@+id/tabletPlaceText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:textColor="@color/notion_ink"
                android:textSize="28sp"
                android:textStyle="bold"
                tools:text="Kioto" />

            <TextView
                android:id="@+id/tabletDateText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/notion_slate"
                android:textSize="16sp"
                tools:text="2026-05-09" />

            <TextView
                android:id="@+id/tabletRatingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_badge_rating"
                android:textColor="@color/notion_charcoal"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="★ 5/5" />

            <TextView
                android:id="@+id/tabletDescriptionText"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="18dp"
                android:layout_weight="1"
                android:textColor="@color/notion_charcoal"
                android:textSize="16sp"
                tools:text="Descripción completa del viaje." />

            <Button
                android:id="@+id/tabletOpenButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_button_primary"
                android:text="@string/edit_trip"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
