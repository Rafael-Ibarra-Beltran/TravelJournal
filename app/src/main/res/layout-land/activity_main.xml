<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/notion_surface_soft"
    android:orientation="horizontal"
    android:paddingStart="32dp"
    android:paddingTop="18dp"
    android:paddingEnd="32dp"
    android:paddingBottom="18dp"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="310dp"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingEnd="4dp">

            <ImageView
                android:id="@+id/mainLogoImage"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center_horizontal"
                android:contentDescription="@string/logo_content_description"
                android:scaleType="fitCenter"
                android:src="@drawable/travel_journal_logo" />

            <TextView
                android:id="@+id/mainTitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="@string/main_title"
                android:textColor="@color/notion_ink"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/mainSubtitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:text="@string/main_subtitle"
                android:textColor="@color/notion_slate"
                android:textSize="13sp" />

            <Button
                android:id="@+id/addTripButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button_primary"
                android:minWidth="144dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:text="@string/add_trip"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/statsPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card_mint"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/statsTotalText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/notion_ink"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="3" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/stats_total_label"
                    android:textColor="@color/notion_slate"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/statsAverageText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:textColor="@color/notion_ink"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="4.7★" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/stats_average_label"
                    android:textColor="@color/notion_slate"
                    android:textSize="12sp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/filterPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_filter_panel"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:id="@+id/filterHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/filters_title"
                        android:textColor="@color/notion_ink"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/filterToggleText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⌄"
                        android:textColor="@color/notion_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/filterBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <EditText
                        android:id="@+id/searchEditText"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_filter_control"
                        android:hint="@string/search_trip_hint"
                        android:imeOptions="actionSearch"
                        android:inputType="textCapWords"
                        android:maxLines="1"
                        android:textColor="@color/notion_ink"
                        android:textColorHint="@color/notion_steel"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/rating_filter_label"
                        android:textColor="@color/notion_slate"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/ratingFilterSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="5dp"
                        android:background="@drawable/bg_filter_control" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/sort_filter_label"
                        android:textColor="@color/notion_slate"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/sortBySpinner"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="5dp"
                        android:background="@drawable/bg_filter_control" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/sort_direction_label"
                        android:textColor="@color/notion_slate"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/sortDirectionSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="5dp"
                        android:background="@drawable/bg_filter_control" />

                    <Button
                        android:id="@+id/clearFiltersButton"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_button_primary"
                        android:text="@string/clear_filters"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="16dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/emptyStateLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_lavender"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:id="@+id/emptyTitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/empty_trips"
                android:textColor="@color/notion_ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/emptyHintText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/empty_trips_hint"
                android:textColor="@color/notion_slate"
                android:textSize="14sp" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/tripsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp"
            tools:listitem="@layout/item_trip" />
    </LinearLayout>
</LinearLayout>
