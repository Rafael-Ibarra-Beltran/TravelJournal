<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/notion_surface_soft"
    android:orientation="horizontal"
    android:padding="28dp"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="350dp"
        android:layout_height="match_parent"
        android:background="@drawable/bg_card"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="22dp">

        <ScrollView
            android:id="@+id/topContentScroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:fillViewport="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

        <ImageView
            android:id="@+id/mainLogoImage"
            android:layout_width="128dp"
            android:layout_height="128dp"
            android:layout_gravity="center_horizontal"
            android:contentDescription="@string/logo_content_description"
            android:scaleType="fitCenter"
            android:src="@drawable/travel_journal_logo" />

        <TextView
            android:id="@+id/mainTitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="@string/main_title"
            android:textColor="@color/notion_ink"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/mainSubtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="@string/main_subtitle"
            android:textColor="@color/notion_slate"
            android:textSize="14sp" />

        <Button
            android:id="@+id/addTripButton"
            android:layout_width="wrap_content"
            android:layout_height="46dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_button_primary"
            android:minWidth="164dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="@string/add_trip"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/statsPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card_mint"
            android:orientation="horizontal"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/statsTotalText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/notion_ink"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="3" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stats_total_label"
                    android:textColor="@color/notion_slate"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/statsAverageText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/notion_ink"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="4.7★" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stats_average_label"
                    android:textColor="@color/notion_slate"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/statsFavoriteText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/notion_ink"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stats_favorites_label"
                    android:textColor="@color/notion_slate"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/dashboardExtraHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card_lavender"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/dashboard_extra_title"
                android:textColor="@color/notion_ink"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dashboardToggleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⌄"
                android:textColor="@color/notion_primary"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/dashboardExtraPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card_lavender"
            android:orientation="vertical"
            android:padding="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/statsBudgetText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/notion_ink"
                android:textStyle="bold"
                tools:text="$ 2,000.00" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/stats_budget_label"
                android:textColor="@color/notion_slate"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/statsBestText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/notion_ink"
                android:textStyle="bold"
                tools:text="Kioto" />

            <TextView
                android:id="@+id/statsLatestText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/notion_ink"
                android:textStyle="bold"
                tools:text="Cancún" />

            <TextView
                android:id="@+id/statsCategoryText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/notion_ink"
                android:textStyle="bold"
                tools:text="Playa" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/filterPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_filter_panel"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout
                android:id="@+id/filterHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/filters_title"
                    android:textColor="@color/notion_ink"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/filterToggleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⌄"
                    android:textColor="@color/notion_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/filterBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

            <EditText
                android:id="@+id/searchEditText"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_filter_control"
                android:hint="@string/search_trip_hint"
                android:imeOptions="actionSearch"
                android:inputType="textCapWords"
                android:maxLines="1"
                android:textColor="@color/notion_ink"
                android:textColorHint="@color/notion_steel"
                android:textSize="14sp" />

            <CheckBox
                android:id="@+id/favoriteFilterCheckBox"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:buttonTint="@color/notion_primary"
                android:text="@string/favorite_filter_label"
                android:textColor="@color/notion_charcoal"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/category_filter_label"
                android:textColor="@color/notion_slate"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/categoryFilterSpinner"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_filter_control" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/rating_filter_label"
                android:textColor="@color/notion_slate"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/ratingFilterSpinner"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_filter_control" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/sort_filter_label"
                android:textColor="@color/notion_slate"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/sortBySpinner"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_filter_control" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/sort_direction_label"
                        android:textColor="@color/notion_slate"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/sortDirectionSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_filter_control" />
                </LinearLayout>

                <Button
                    android:id="@+id/clearFiltersButton"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_button_primary"
                    android:minWidth="92dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="@string/clear_filters"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
            </LinearLayout>
        </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:id="@+id/tripsSection"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/trips_section_title"
                    android:textColor="@color/notion_ink"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:background="@color/notion_hairline_strong" />
            </LinearLayout>

        <LinearLayout
            android:id="@+id/emptyStateLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_lavender"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:id="@+id/emptyTitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/empty_trips"
                android:textColor="@color/notion_ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/emptyHintText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/empty_trips_hint"
                android:textColor="@color/notion_slate"
                android:textSize="14sp" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/tripsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="18dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="true"
            android:paddingBottom="8dp"
            tools:listitem="@layout/item_trip" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="26dp"
        android:layout_weight="1">

        <TextView
            android:id="@+id/tabletEmptyDetailText"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_card"
            android:gravity="center"
            android:padding="32dp"
            android:text="@string/tablet_empty_detail"
            android:textColor="@color/notion_slate"
            android:textSize="20sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/tabletDetailPanel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="26dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/tabletImageView"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:background="@drawable/bg_image_placeholder"
                android:contentDescription="@string/trip_photo_content_description"
                android:scaleType="centerInside"
                android:src="@drawable/ic_image_placeholder" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:overScrollMode="ifContentScrolls"
                android:scrollbars="none">

            <LinearLayout
                android:id="@+id/tabletGalleryRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageView
                    android:id="@+id/tabletGalleryImageOne"
                    android:layout_width="108dp"
                    android:layout_height="108dp"
                    android:background="@drawable/bg_image_placeholder"
                    android:clickable="true"
                    android:contentDescription="@string/trip_photo_content_description"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_image_placeholder" />

                <ImageView
                    android:id="@+id/tabletGalleryImageTwo"
                    android:layout_width="108dp"
                    android:layout_height="108dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_image_placeholder"
                    android:clickable="true"
                    android:contentDescription="@string/trip_photo_content_description"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_image_placeholder" />

                <ImageView
                    android:id="@+id/tabletGalleryImageThree"
                    android:layout_width="108dp"
                    android:layout_height="108dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_image_placeholder"
                    android:clickable="true"
                    android:contentDescription="@string/trip_photo_content_description"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_image_placeholder" />
            </LinearLayout>
            </HorizontalScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tabletPlaceText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="start"
                        android:textColor="@color/notion_ink"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        tools:text="Kioto" />

                    <TextView
                        android:id="@+id/tabletDateText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="start"
                        android:textColor="@color/notion_slate"
                        android:textSize="16sp"
                        tools:text="2026-05-09" />

                    <TextView
                        android:id="@+id/tabletCompanionsText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/notion_slate"
                        android:textSize="14sp"
                        tools:text="Viajé con: Amigos" />

                    <TextView
                        android:id="@+id/tabletBudgetText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/notion_slate"
                        android:textSize="14sp"
                        tools:text="Gasto: $ 1,250.00" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:gravity="end|center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tabletCategoryText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_mint"
                        android:paddingStart="14dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="6dp"
                        android:textColor="@color/notion_charcoal"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="Cultura" />

                    <TextView
                        android:id="@+id/tabletFavoriteText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_card_peach"
                        android:paddingStart="14dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="6dp"
                        android:text="@string/favorite_badge"
                        android:textColor="@color/notion_charcoal"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <TextView
                        android:id="@+id/tabletRatingText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_badge_rating"
                        android:textColor="@color/notion_charcoal"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="★ 5/5" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tabletDescriptionText"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="18dp"
                android:layout_weight="1"
                android:textColor="@color/notion_charcoal"
                android:textSize="16sp"
                tools:text="Descripción completa del viaje." />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:gravity="center"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/tabletOpenButton"
                    android:layout_width="wrap_content"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_button_primary"
                    android:minWidth="150dp"
                    android:paddingStart="22dp"
                    android:paddingEnd="22dp"
                    android:text="@string/edit_trip"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
